{
  "expo": {
    "name": "boostifywrite",
    "slug": "boostifywrite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "boostifywrite",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EFF0FA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.boostify.write"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#EFF0FA"
      },
      "package": "com.boostify.write"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
